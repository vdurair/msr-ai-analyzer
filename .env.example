# Backend settings
BACKEND_PORT=4000
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token

# Story points field (optional)
JIRA_STORY_POINTS_FIELD=customfield_10016

# Label prefixes (labels like channel-aa, team-alpha, train-a)
JIRA_CHANNEL_LABEL_PREFIX=channel-
JIRA_TEAM_LABEL_PREFIX=team-
JIRA_TRAIN_LABEL_PREFIX=train-

# Frontend default project key
REACT_APP_JIRA_PROJECT_KEY=TM

# OpenAI settings for AI Insights
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
